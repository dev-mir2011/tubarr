{
  "branches": ["main"],
  "tagFormat": "v${version}",
  "plugins": [
    [
      "@semantic-release/commit-analyzer",
      {
        "preset": "conventionalcommits"
      }
    ],
    [
      "@semantic-release/release-notes-generator",
      {
        "preset": "conventionalcommits"
      }
    ],
    [
      "@semantic-release/changelog",
      {
        "changelogFile": "CHANGELOG.md"
      }
    ],

    [
      "@semantic-release/github",
      {
        "successComment": false,
        "failComment": false
      }
    ],

    [
      "@semantic-release/exec",
      {
        "publishCmd": "if [ -n \"$ACCESS_TOKEN\" ]; then curl -s -X POST $GITEA_URL/api/v1/repos/$GITEA_REPO/releases -H \"Authorization: token $ACCESS_TOKEN\" -H \"Content-Type: application/json\" -d '{\"tag_name\":\"v${nextRelease.version}\",\"name\":\"v${nextRelease.version}\",\"body\":${JSON.stringify(nextRelease.notes)}}'; fi"
      }
    ],

    [
      "@semantic-release/git",
      {
        "assets": ["CHANGELOG.md", "package.json"],
        "message": "chore(release): v${nextRelease.version} [skip ci]\n\n${nextRelease.notes}"
      }
    ]
  ]
}
